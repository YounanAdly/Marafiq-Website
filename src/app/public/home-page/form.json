[
    {
        "fieldGroup": [
            {
                "key": "name",
                "type": "custom-input",
                "props": {
                    "label": "HELLO",
                    "placeholder": "WELCOME",
                    "required": true,
                    "translate": true
                }
            },
            {
                "key": "country",
                "type": "custom-dropdown",
                "props": {
                    "label": "HELLO",
                    "placeholder": "WELCOME",
                    "required": true,
                    "translate": true
                }
            },
            {
                "key": "date",
                "type": "custom-calendar",
                "props": {
                    "label": "HELLO",
                    "placeholder": "WELCOME",
                    "required": true,
                    "translate": true
                }
            },
            {
                "key": "multi",
                "type": "custom-multiselect",
                "props": {
                    "label": "HELLO",
                    "placeholder": "WELCOME",
                    "required": true,
                    "translate": true
                }
            },
            {
                "key": "profileImage",
                "type": "file",
                "templateOptions": {
                    "label": "Profile Picture",
                    "multiple": false,
                    "accept": "image/*",
                    "maxFileSize": 2000000
                }
            },
            {
                "key": "attachments",
                "type": "file",
                "templateOptions": {
                    "label": "Attachments",
                    "multiple": true,
                    "accept": ".pdf,.doc,.docx,.jpg,.png",
                    "maxFileSize": 10000000
                }
            },
            {
                "key": "searchableSelect",
                "type": "searchable-select",
                "props": {
                    "label": "Photos",
                    "placeholder": "Select a photo",
                    "apiUrl": "https://jsonplaceholder.typicode.com/photos",
                    "bindLabel": "title",
                    "bindValue": "id",
                    "virtualScroll": true
                }
            }
        ]
    }
]