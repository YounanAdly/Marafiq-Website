{
  "name": "custom-template",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:custom-template": "node dist/custom-template/server/server.mjs",
    "start:dev": "ng serve --configuration=development",
    "start:prod": "ng serve --configuration=production",
    "start:default": "ng serve --configuration=default",
    "build:dev": "ng build --configuration=development",
    "build:prod": "ng build --configuration=production --production",
    "build:default": "ng build --configuration=default"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.5",
    "@angular/common": "^20.3.5",
    "@angular/compiler": "^20.3.5",
    "@angular/core": "^20.3.5",
    "@angular/forms": "^20.3.5",
    "@angular/platform-browser": "^20.3.5",
    "@angular/platform-browser-dynamic": "^20.3.5",
    "@angular/platform-server": "^20.3.5",
    "@angular/router": "^20.3.5",
    "@angular/ssr": "^20.3.6",
    "@ngx-formly/bootstrap": "^7.0.0",
    "@ngx-formly/core": "^7.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@primeng/themes": "^20.2.0",
    "bootstrap": "^5.3.8",
    "express": "^5.1.0",
    "primeicons": "^7.0.0",
    "primeng": "^20.2.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.6",
    "@angular/cli": "^20.3.6",
    "@angular/compiler-cli": "^20.3.5",
    "@types/express": "^5.0.3",
    "@types/jasmine": "~5.1.11",
    "@types/node": "^24.7.2",
    "jasmine-core": "~5.12.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}